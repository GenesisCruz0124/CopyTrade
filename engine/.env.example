# --- MEXC API credentials (spot trade permission ONLY, no withdrawal, IP-whitelisted) ---
MEXC_API_KEY=
MEXC_API_SECRET=

# --- Trading mode ---
# paper (default, simulated) | live (real orders — also requires confirmLive:true per bot)
TRADING_MODE=paper

# --- Control API ---
API_AUTH_TOKEN=change-me-to-a-long-random-string
PORT=8080
HOST=0.0.0.0

# --- Persistence ---
DB_PATH=./data/copytrade.db

# --- Safety rails ---
MAX_ORDER_PRICE_DEVIATION_PCT=5
DEFAULT_DAILY_LOSS_LIMIT_USDT=50

# --- Logging ---
LOG_LEVEL=info
