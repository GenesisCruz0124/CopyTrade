# --- MEXC API credentials (spot trade permission ONLY, no withdrawal, IP-whitelisted) ---
MEXC_API_KEY=
MEXC_API_SECRET=

# --- Trading mode ---
# paper (default, simulated) | live (real orders — also requires confirmLive:true per bot)
TRADING_MODE=paper

# --- Control API ---
API_AUTH_TOKEN=change-me-to-a-long-random-string
PORT=8080
HOST=0.0.0.0

# --- Persistence ---
DB_PATH=./data/copytrade.db

# --- Safety rails ---
MAX_ORDER_PRICE_DEVIATION_PCT=5
DEFAULT_DAILY_LOSS_LIMIT_USDT=50

# --- Logging ---
LOG_LEVEL=info

# --- MEXC Futures (contract.mexc.com) — a SEPARATE key pair from Spot above.
# Create it under Futures API Management on MEXC. Only required for
# FUTURES_TRADING_MODE=live below — paper mode works without these set. ---
MEXC_FUTURES_ACCESS_KEY=
MEXC_FUTURES_SECRET_KEY=
MAX_FUTURES_LEVERAGE=20
MIN_LIQUIDATION_DISTANCE_PCT=15

# --- Futures trading mode — INDEPENDENT of TRADING_MODE above. ---
# paper (default, simulated fills using real live prices, no real orders sent,
#   no MEXC_FUTURES_ACCESS_KEY/SECRET_KEY needed) | live (real orders — also
#   requires confirmLive:true per manual position). Governs manual futures
#   trading, futures bots, and the copy-trading pipeline uniformly.
FUTURES_TRADING_MODE=paper
# Simulated starting balance for paper mode, reset on every engine restart.
FUTURES_PAPER_SEED_BALANCE_USDT=50000

# --- Discord copy-signal channel + Claude vision extraction ---
# All three are required together to enable the copy-trading pipeline.
DISCORD_BOT_TOKEN=
DISCORD_SIGNAL_CHANNEL_ID=
ANTHROPIC_API_KEY=
SIGNAL_IMAGE_DIR=./data/copy-signal-images

# --- Copy-trading position sizing ---
# Every approved signal risks COPY_TRADING_RISK_PCT_PER_TRADE% of this budget
# as margin, at COPY_TRADING_DEFAULT_LEVERAGE (or the signal's own leverage
# if it parsed one). This is a per-trade cap, not a cumulative account guard —
# see the README's Copy trading section before enabling in live mode.
COPY_TRADING_BUDGET_USDT=100
COPY_TRADING_RISK_PCT_PER_TRADE=2
COPY_TRADING_DEFAULT_LEVERAGE=3
COPY_TRADING_MARGIN_MODE=isolated

# --- Multi-user auth ---
# Only required once a user saves their own MEXC API keys via /me/exchange-keys
# (used to encrypt them at rest with AES-256-GCM). Set to a long random string
# before enabling multi-user signups; existing single-tenant deployments using
# only API_AUTH_TOKEN can leave this blank.
CREDENTIALS_ENCRYPTION_KEY=
