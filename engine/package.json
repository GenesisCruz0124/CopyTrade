{
  "name": "copytrade-engine",
  "version": "1.0.0",
  "description": "CopyTrade engine - MEXC Spot grid/DCA trading bot",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
