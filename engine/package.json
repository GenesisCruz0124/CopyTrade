    "ws": "^8.18.0",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "discord.js": "^14.16.3",
    "@anthropic-ai/sdk": "^0.27.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.15",
    "@types/ws": "^8.5.12",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
